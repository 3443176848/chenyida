# Copy to .env and replace every CHANGE_ME value. Never commit .env.
ERP_ENV=development
POSTGRES_DB=chenyida_erp
POSTGRES_USER=chenyida_erp
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
DATABASE_URL=postgresql://chenyida_erp:replace-with-the-same-password@postgres:5432/chenyida_erp
ERP_SETUP_TOKEN=replace-with-a-long-random-one-time-setup-token
ERP_UPLOAD_ROOT=/data/chenyida-erp/uploads
ERP_ATTACHMENT_ROOT=/data/chenyida-erp/attachments
ERP_MAX_UPLOAD_BYTES=10485760
ERP_WORKER_POLL_MS=1000
ERP_WORKER_LEASE_SECONDS=60
DATABASE_POOL_MAX=10
PORT=3000

# Used only by `docker compose --profile production up`.
ERP_DOMAIN=erp.example.com

# Supply these only to the one-shot admin command; never store a real password here.
# ERP_ADMIN_USERNAME=admin
# ERP_ADMIN_DISPLAY_NAME=系统管理员
# ERP_ADMIN_PASSWORD=CHANGE_ME_AT_COMMAND_TIME

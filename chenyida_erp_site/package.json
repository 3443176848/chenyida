{
  "name": "site-creator-vinext-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "test": "npm run build && node --experimental-strip-types --test tests/*.test.mjs",
    "test:environment": "node --test tests/environment-guard.test.mjs",
    "test:api": "node scripts/run-api-smoke.mjs",
    "test:material-query-plan": "node scripts/material-query-plan.mjs",
    "material-library:import": "node --experimental-strip-types scripts/material-library-import.mjs",
    "seed:material-categories": "node --experimental-strip-types scripts/seed-material-categories.ts",
    "security:credentials": "node scripts/check-credentials.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@zip.js/zip.js": "2.8.26",
    "csv-parse": "7.0.1",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sax-wasm": "3.1.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}

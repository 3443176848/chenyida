{
  "name": "site-creator-vinext-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "worker": "node --experimental-strip-types worker/selfhost.ts",
    "db:migrate": "node --experimental-strip-types scripts/migrate-postgres.ts",
    "admin:init": "node --experimental-strip-types scripts/init-admin.ts",
    "test": "node --experimental-strip-types --test tests/selfhost-file-storage.test.mjs",
    "test:legacy": "npm run build && node --experimental-strip-types --test tests/*.test.mjs",
    "test:postgres": "node --experimental-strip-types --test tests/selfhost-postgres.test.mjs",
    "test:material:unit": "node --experimental-strip-types --test tests/selfhost-material-unit.test.mjs",
    "test:material:ui": "node --experimental-strip-types --test tests/selfhost-material-ui-contract.test.mjs",
    "test:material:postgres": "node --experimental-strip-types --test tests/selfhost-material-postgres.test.mjs",
    "test:mapping:unit": "node --experimental-strip-types --test tests/selfhost-mapping-unit.test.mjs",
    "test:mapping:ui": "node --experimental-strip-types --test tests/selfhost-mapping-ui-contract.test.mjs",
    "test:mapping:postgres": "node --experimental-strip-types --test --test-concurrency=1 tests/selfhost-mapping-postgres.test.mjs",
    "test:mapping:migration-upgrade": "node --experimental-strip-types --test tests/selfhost-mapping-migration-upgrade.test.mjs",
    "test:normalization:unit": "node --experimental-strip-types --test tests/selfhost-normalization-unit.test.mjs",
    "test:normalization:postgres": "node --experimental-strip-types --test --test-concurrency=1 tests/selfhost-normalization-postgres.test.mjs",
    "test:normalization:ui": "node --experimental-strip-types --test tests/selfhost-normalization-ui-contract.test.mjs",
    "test:normalization:migration-upgrade": "node --experimental-strip-types --test tests/selfhost-normalization-migration-upgrade.test.mjs",
    "typecheck:normalization": "tsc -p tsconfig.task03.json --pretty false",
    "typecheck:review": "tsc -p tsconfig.task04.json --pretty false",
    "test:review:unit": "node --experimental-strip-types --test tests/selfhost-review-unit.test.mjs",
    "test:review:postgres": "node --experimental-strip-types --test --test-concurrency=1 tests/selfhost-review-postgres.test.mjs",
    "test:review:ui": "node --experimental-strip-types --test tests/selfhost-review-ui-contract.test.mjs",
    "test:compose": "node scripts/selfhost-compose-smoke.mjs",
    "test:normalization:compose-restart": "node scripts/selfhost-normalization-restart-smoke.mjs",
    "test:review:compose-restart": "node scripts/selfhost-review-restart-smoke.mjs",
    "test:material:compose": "node scripts/selfhost-material-compose-smoke.mjs",
    "test:environment": "node --test tests/environment-guard.test.mjs",
    "test:api": "node scripts/run-api-smoke.mjs",
    "test:material-query-plan": "node scripts/material-query-plan.mjs",
    "material-library:import": "node --experimental-strip-types scripts/material-library-import.mjs",
    "seed:material-categories": "node --experimental-strip-types scripts/seed-material-categories.ts",
    "security:credentials": "node scripts/check-credentials.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate --name selfhost_baseline"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@zip.js/zip.js": "2.8.26",
    "csv-parse": "7.0.1",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "pg": "8.16.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sax-wasm": "3.1.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/pg": "8.15.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13"
  },
  "type": "module"
}

# Unified environment selection: development, test, or production.
ERP_ENV=development

# Site runtime addresses. Production values must be supplied by the managed
# environment and must never be committed here.
ERP_API_URL=http://127.0.0.1:3000/api
ERP_SITE_URL=http://127.0.0.1:3000
ERP_LOG_LEVEL=debug
ERP_DEBUG=true

# Local-only persistence. The test runner replaces this with an automatically
# created operating-system temporary directory.
ERP_D1_PERSIST_PATH=chenyida_erp_site/.wrangler/state

# Local Python/SQLite runtime. Tests override both paths with temporary paths.
CYD_ERP_DATA_DIR=chenyida_erp_app/data
CYD_ERP_DB=chenyida_erp_app/data/erp.sqlite3

# Secret values must be supplied locally or through the hosting control plane.
ERP_SETUP_TOKEN=replace-with-a-long-random-one-time-token
